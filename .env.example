# =============================================================================
# YGB Environment Configuration
# =============================================================================
# Copy this file to .env and start the server.
# =============================================================================

# Database
DATABASE_URL=sqlite:///C:/ygb_data/ygb.db
DATABASE_BACKUP_PATH=C:/ygb_data/ygb_backup.db

# Storage Tiering
YGB_SSD_ROOT=C:/ygb_data
YGB_HDD_ROOT=C:/ygb_hdd
YGB_SSD_CAP_GB=110

# JWT Authentication
JWT_SECRET=<ask-owner-for-jwt-secret>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# SMTP Email Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hacker05090204@gmail.com
SMTP_PASS=<ask-owner-for-smtp-app-password>
SMTP_PASSWORD=<ask-owner-for-smtp-app-password>
SMTP_USE_TLS=true
ALERT_EMAIL_TO=hacker05090204@gmail.com
ALERT_EMAIL_FROM=hacker05090204@gmail.com

# GitHub OAuth
GITHUB_CLIENT_ID=Ov23liHtMNFZ096bZUE6
GITHUB_CLIENT_SECRET=<ask-owner-for-github-client-secret>
GITHUB_REDIRECT_URI=https://ygb-nas.tail7521c4.ts.net:8443/auth/github/callback

# Google OAuth
GOOGLE_CLIENT_ID=516476936580-41897h9ghok3c15e9h7svrgq3tblo9dl.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<ask-owner-for-google-client-secret>
GOOGLE_REDIRECT_URI=https://ygb-nas.tail7521c4.ts.net:8443/auth/google/callback

# Frontend URL
FRONTEND_URL=https://ygb-nas.tail7521c4.ts.net
YGB_TAILSCALE_AUTO_CONNECT=true
YGB_TAILSCALE_OWNER_ACCOUNT=hacker05090204@gmail.com
YGB_TAILSCALE_HOSTNAME=ygb-nas
YGB_TAILSCALE_OPEN_BROWSER=true
YGB_TAILSCALE_AUTO_SERVE=true

# Rate Limiting
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Auth Mode
ALLOW_PASSWORD_LOGIN=true
YGB_TEMP_AUTH_BYPASS=false
YGB_TEMP_AUTH_ROLE=admin

# Server
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false
ENABLE_G38_AUTO_TRAINING=true

# Training Telemetry
YGB_HMAC_SECRET=<generate-with-secrets.token_hex(32)>

# Video Streamer JWT
YGB_VIDEO_JWT_SECRET=<ask-owner-for-video-jwt-secret>

# === SYNC ENGINE CONFIG ===
# Device ID — unique identifier for this machine in the sync mesh
YGB_DEVICE_ID=laptop_a
# Root directory for sync data
YGB_SYNC_ROOT=D:\
# Sync interval in seconds (5 minutes default)
YGB_SYNC_INTERVAL_SEC=300
# Chunk size for file transfers
YGB_CHUNK_SIZE_MB=64

# Peer nodes for sync mesh: name:ip:port (comma-separated)
# Add your peer machines here. Use Tailscale IPs for secure connectivity.
# YGB_PEER_NODES=laptop_b:100.64.0.2:8000,laptop_c:100.64.0.3:8000

# Google Drive backup (disabled until credentials configured)
YGB_GDRIVE_ENABLED=false
# YGB_GDRIVE_FOLDER_ID=
# YGB_GDRIVE_CREDENTIALS_PATH=C:/ygb_data/gdrive_service_account.json

# Retention (days)
YGB_RETENTION_VIDEOS=30
YGB_RETENTION_LOGS=14
YGB_RETENTION_REPORTS=90
