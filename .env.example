# ╔══════════════════════════════════════════════════════════════╗
# ║          YGB Environment Variables — TEMPLATE               ║
# ║  Copy this to .env and fill in real values.                 ║
# ║  NEVER commit .env — only .env.example is tracked in git.   ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Required Secrets (server will NOT start without these) ────
# Generate each with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
YGB_HMAC_SECRET=
YGB_VIDEO_JWT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────
# Get these from: https://github.com/settings/developers
# Callback URL must match your GitHub OAuth App settings!
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Dynamic callback — set only if you need to force a specific URL:
# GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Frontend URL ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///D:/ygb_data/ygb.db

# ── Storage (HDD/SSD tiering) ────────────────────────────────
YGB_SSD_ROOT=C:/ygb_data
YGB_HDD_ROOT=D:/ygb_data
YGB_SSD_CAP_GB=110

# ── Server Settings ──────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false

# ── Alerting ──────────────────────────────────────────────────
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ALERT_RECIPIENT=admin@example.com

# ── Training ──────────────────────────────────────────────────
ENABLE_G38_AUTO_TRAINING=true

# ── Sync Engine ───────────────────────────────────────────────
YGB_DEVICE_ID=laptop_a
YGB_SYNC_ROOT=D:\
YGB_SYNC_INTERVAL_SEC=300
YGB_CHUNK_SIZE_MB=64
# Peer nodes: name:ip:port (comma-separated)
# YGB_PEER_NODES=laptop_b:100.64.0.2:8000,laptop_c:100.64.0.3:8000
# Google Drive backup
YGB_GDRIVE_ENABLED=false
# YGB_GDRIVE_FOLDER_ID=
# YGB_GDRIVE_CREDENTIALS_PATH=C:/ygb_data/gdrive_service_account.json
# Generate encryption key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# YGB_BACKUP_ENCRYPTION_KEY=
YGB_RETENTION_VIDEOS=30
YGB_RETENTION_LOGS=14
YGB_RETENTION_REPORTS=90
