# =============================================================================
# YGB Environment Configuration — EXAMPLE
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets.
# Generate secrets with: python -c "import secrets; print(secrets.token_hex(32))"

# Database — SQLite on SSD for speed, HDD backup
DATABASE_URL=sqlite:///C:/ygb_data/ygb.db
DATABASE_BACKUP_PATH=D:/ygb_data/ygb.db

# Storage Tiering — training on SSD, videos/logs/user data on HDD
YGB_SSD_ROOT=C:/ygb_data
YGB_HDD_ROOT=D:/ygb_hdd
YGB_SSD_CAP_GB=110

# JWT Authentication — GENERATE A REAL SECRET (min 32 chars)
JWT_SECRET=CHANGE_ME_GENERATE_WITH_secrets_token_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# SMTP Email Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=

# GitHub OAuth — Get from https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# Rate Limiting
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Auth Mode
ALLOW_PASSWORD_LOGIN=true

# Server
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false
ENABLE_G38_AUTO_TRAINING=false

# Training Telemetry — GENERATE A REAL SECRET (min 32 chars)
YGB_HMAC_SECRET=CHANGE_ME_GENERATE_WITH_secrets_token_hex_32

# Video Streamer JWT — GENERATE A REAL SECRET (min 32 chars)
YGB_VIDEO_JWT_SECRET=CHANGE_ME_GENERATE_WITH_secrets_token_hex_32
